+#ifndef CATLASS_ACLNN_TILING_CACHE_H
+#define CATLASS_ACLNN_TILING_CACHE_H
+
+#include <map>
+#include <memory>
+#include <vector>
+#include <iostream>
+
+#include "tiling_params.h"
+#include "csv.h"
+#include "utils.h"
+
+namespace CatlassTiling {
+namespace Cache {
+// (m, n, k, layoutTagA, layoutTagB, layoutTagC)
+using CacheKey = std::tuple<uint32_t, uint32_t, uint32_t, uint8_t, uint8_t, uint8_t>;
+using CacheValue = TilingParams;
+
+class TilingCache {
+public:
+    bool GetTiling(TilingParams& tilingParams);
+
+    void SetTiling(const TilingParams& tilingParams);
+
+    static TilingCache& GetInstance()
+    {
+        static TilingCache cacheInstance;
+        return cacheInstance;
+    }
+
+private:
+    void Init(const std::string cacheFilePath);
+    void ParseCacheRow(TilingParams& tilingParams, size_t rowIndex);
+
+    TilingCache();
+
+    ~TilingCache() {}
+    TilingCache(const TilingCache&) = delete;
+    TilingCache &operator=(const TilingCache&) = delete;
+
+private:
+    std::map<CacheKey, CacheValue> data_;
+    std::unique_ptr<CSV::Document> cacheDoc_ = nullptr;
+    bool enableFile_ = false;
+};
+
+TilingCache::TilingCache()
+{
+    std::string cacheFilePath = GetEnv("DGA_CACHE_FILE_PATH");
+    Init(cacheFilePath);
+}
+
+void TilingCache::Init(const std::string cacheFilePath)
+{
+    if (cacheFilePath == "") {
+        // no cache ENV, will not use cache file
+        std::cerr << "[DGA] [INFO] Cache file path is empty." << std::endl;
+        return;
+    }
+
+    std::unique_ptr<CSV::Document> tempDoc(new CSV::Document(cacheFilePath));
+    if (tempDoc == nullptr || !tempDoc->IsEnable()) {
+        // Document create failed, will not use cache file
+        std::cerr << "[DGA] [ERROR] Create file cache failed." << std::endl;
+        return;
+    }
+    cacheDoc_ = std::move(tempDoc);
+    size_t rowCount = cacheDoc_->GetRowCount();
+    for (size_t i = 0; i < rowCount; i++) {
+        TilingParams tempParams;
+        ParseCacheRow(tempParams, i);
+        CacheKey tempKey = std::make_tuple(tempParams.m, tempParams.n, tempParams.k,
+            tempParams.layoutTagA, tempParams.layoutTagB, tempParams.layoutTagC);
+        data_[tempKey] = std::move(tempParams);
+    }
+    enableFile_ = true;
+}
+
+bool TilingCache::GetTiling(TilingParams& tilingParams)
+{
+    CacheKey tempKey = std::make_tuple(tilingParams.m, tilingParams.n, tilingParams.k,
+        tilingParams.layoutTagA, tilingParams.layoutTagB, tilingParams.layoutTagC);
+    if (data_.find(tempKey) != data_.end()) {
+        tilingParams = data_[tempKey];
+        return true;
+    }
+    for (auto &item : data_) {
+        printf("[%d, %d, %d, %d, %d, %d]\n",
+            std::get<0>(item.first), std::get<1>(item.first), std::get<2>(item.first),
+            std::get<3>(item.first), std::get<4>(item.first), std::get<5>(item.first));
+    }
+    return false;
+}
+
+void  TilingCache::ParseCacheRow(TilingParams& tilingParams, size_t rowIndex)
+{
+    uint32_t m = cacheDoc_->GetCell<uint32_t>("m", rowIndex);
+    uint32_t n = cacheDoc_->GetCell<uint32_t>("n", rowIndex);
+    uint32_t k = cacheDoc_->GetCell<uint32_t>("k", rowIndex);
+    LayoutTag layoutTagA = static_cast<LayoutTag>(cacheDoc_->GetCell<uint32_t>("layoutTagA", rowIndex));
+    LayoutTag layoutTagB = static_cast<LayoutTag>(cacheDoc_->GetCell<uint32_t>("layoutTagB", rowIndex));
+    LayoutTag layoutTagC = static_cast<LayoutTag>(cacheDoc_->GetCell<uint32_t>("layoutTagC", rowIndex));
+    tilingParams.SetParams(m, n, k, layoutTagA, layoutTagB, layoutTagC);
+
+    tilingParams.m1 = cacheDoc_->GetCell<uint32_t>("m1", rowIndex);
+    tilingParams.n1 = cacheDoc_->GetCell<uint32_t>("n1", rowIndex);
+    tilingParams.k1 = cacheDoc_->GetCell<uint32_t>("k1", rowIndex);
+    tilingParams.paddingTagA = static_cast<uint8_t>(cacheDoc_->GetCell<uint32_t>("paddingTagA", rowIndex));
+    tilingParams.paddingTagB = static_cast<uint8_t>(cacheDoc_->GetCell<uint32_t>("paddingTagB", rowIndex));
+    tilingParams.paddingTagC = static_cast<uint8_t>(cacheDoc_->GetCell<uint32_t>("paddingTagC", rowIndex));
+    tilingParams.blockDim = static_cast<uint8_t>(cacheDoc_->GetCell<uint32_t>("blockDim", rowIndex));
+    tilingParams.swizzleOffset = 3;
+    if (tilingParams.m > tilingParams.n) {
+        tilingParams.swizzleDirection = 0;
+    } else {
+        tilingParams.swizzleDirection = 1;
+    }
+
+    uint8_t kernelSerial = static_cast<uint8_t>(cacheDoc_->GetCell<uint32_t>("kernelSerial", rowIndex));
+    tilingParams.tilingKey.SetTilingKey(kernelSerial,
+        tilingParams.layoutTagA, tilingParams.layoutTagB, tilingParams.layoutTagC,
+        tilingParams.paddingTagA, tilingParams.paddingTagB, tilingParams.paddingTagC);
+}
+
+} // namespace Cache
+} // namespace CatlassTiling
+
+#endif // CATLASS_ACLNN_TILING_CACHE_H
